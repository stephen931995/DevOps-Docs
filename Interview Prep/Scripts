4. DR environments often die. You need to ensure the secondary region is reachable and active.


	import requests
	
	REGIONS = {"Primary": "https://api.primary.com", "DR": "https://api.dr.com"}
	
	def check_health():
	    for name, url in REGIONS.items():
	        try:
	            resp = requests.get(f"{url}/health", timeout=5)
	            status = "UP" if resp.status_code == 200 else "DOWN"
	            print(f"{name} Region Health: {status}")
	        except Exception:
	            print(f"ALERT: {name} Region is UNREACHABLE!")
	
	check_health()


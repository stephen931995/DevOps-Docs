	1. Self-Healing: Automated Disk Cleanup
	
	"Disk Full" alerts on Jenkins workers

	#!/bin/bash
	THRESHOLD=85
	CURRENT_USAGE=$(df /var/log | grep / | awk '{ print $5 }' | sed 's/%//')
	
	if [ "$CURRENT_USAGE" -gt "$THRESHOLD" ]; then
	    echo "Usage high: $CURRENT_USAGE%. Starting cleanup..."
	    # 1. Clean logs older than 7 days
	    find /var/log -type f -name "*.log" -mtime +7 -delete
	    # 2. Clean Docker system prune
	    docker system prune -af --volumes
	    # 3. Alert Slack if still high
	    NEW_USAGE=$(df /var/log | grep / | awk '{ print $5 }' | sed 's/%//')
	    [[ "$NEW_USAGE" -gt "$THRESHOLD" ]] && curl -X POST -d '{"text":"Manual intervention needed"}' $SLACK_WEBHOOK
	 fi

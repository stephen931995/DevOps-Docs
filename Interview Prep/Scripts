 5. SLO Calculator to know the "Availability %" rather than just a list of alerts


	import requests
	import time
	
	PROMETHEUS_URL = "http://prometheus:9090/api/v1/query"
	
	def calculate_availability():
	    # Query: Total success requests / Total requests over last 30 days
	    query = 'sum(rate(http_requests_total{status="200"}[30d])) / sum(rate(http_requests_total[30d])) * 100'
	    response = requests.get(PROMETHEUS_URL, params={'query': query})
	    availability = response.json()['data']['result'][0]['value'][1]
	    
	    print(f"30-Day Availability Score: {float(availability):.2f}%")
	
	calculate_availability()


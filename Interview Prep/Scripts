2. Huge monthly AWS costs from Dev/QA environments running during weekends


	import boto3
	
	ec2 = boto3.resource('ec2', region_name='ap-south-1')
	
	def stop_dev_instances():
	    # Only stop instances with Tag 'Env=Dev' and status 'running'
	    filters = [{'Name': 'tag:Env', 'Values': ['Dev']},
	               {'Name': 'instance-state-name', 'Values': ['running']}]
	    
	    instances = ec2.instances.filter(Filters=filters)
	    ids = [i.id for i in instances]
	    
	    if ids:
	        ec2.instances.filter(InstanceIds=ids).stop()
	        print(f"Stopped {len(ids)} instances to save costs.")
	
	stop_dev_instances()
